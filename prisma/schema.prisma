datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model WorkoutMetric {
  id             String   @id @default(cuid())
  date           DateTime @unique
  runningVolume  Float    
  strengthVolume Float    
  createdAt      DateTime @default(now())
}